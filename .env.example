# Corn & Culture Club — environment variables
# Copy to .env and fill in. .env is gitignored; never commit real keys.

# --- Weather (Phase 1) ---
# NWS api.weather.gov needs NO key. It only asks for a User-Agent identifying
# the app + a contact email. Set that here.
NWS_USER_AGENT="corn-and-culture-club (michael@480th.com)"

# --- Publishing (Phase 4, optional) ---
# beehiiv API key + publication id — only needed if you automate posting
# instead of pasting HTML manually. Leave blank for the manual workflow.
BEEHIIV_API_KEY=""
BEEHIIV_PUBLICATION_ID=""

# --- Tier 3 social scraping (deferred, optional) ---
# Scrape Creators API for Instagram, per the Catskill Crew video. Not needed
# until Tier 1/2 pipelines are solid.
SCRAPE_CREATORS_API_KEY=""
